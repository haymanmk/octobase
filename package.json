{
  "name": "octobase-react-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A note-taking App built for your brain",
  "main": "src/electron/main.js",
  "scripts": {
    "dev": "npm run build && electron --trace-warnings .",
    "dev-react": "react-router dev",
    "vite-dev": "vite",
    "test": "node --test test/**/*.test.ts",
    "build": "tsc -b && vite build && npm run build:highlighter",
    "build:highlighter": "vite build --config vite.highlighter.config.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mozilla/readability": "^0.5.0",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@react-router/node": "^7.9.6",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "isbot": "^5.1.32",
    "lit": "^3.3.2",
    "rangy": "^1.3.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.1.0",
    "react-router": "^7.9.6",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.8.10",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@react-router/dev": "^7.9.6",
    "@types/node": "^24.10.0",
    "@types/rangy": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^39.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "linkedom": "^0.18.12",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
